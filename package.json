  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config ./.eslintrc.cjs . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "cap:sync": "npx cap sync",
